# ══════════════════════════════════════════════════════════════
# Polymarket AI Scalper — Environment Variables
# ══════════════════════════════════════════════════════════════
# Fill in your real values below. NEVER share this file.
# ══════════════════════════════════════════════════════════════

# Anthropic API key (REQUIRED)
# Get one at: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_KEY=sk-ant-api03-YOURKEYHERE

# Polymarket private key (optional — leave blank to run in simulation mode)
# Get from: Polymarket → Settings → Export Private Key
POLY_PRIVATE_KEY=

# Your Polymarket wallet address (optional — needed for live trading)
# Find at: Polymarket → your profile page → copy wallet address
POLY_FUNDER=

# Starting balance in USDC (used in simulation mode)
INITIAL_BALANCE=100

# Max risk per trade as a fraction of balance (0.05 = 5%)
MAX_RISK_PCT=0.05

# How long to run in hours (0 = run until you press Ctrl+C)
DURATION_HOURS=0

# Claude model (leave as-is unless you want to change)
# MODEL=claude-sonnet-4-6
